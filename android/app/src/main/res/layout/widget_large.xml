<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/widget_background"
    android:orientation="vertical"
    android:padding="18dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">
            <TextView
                android:id="@+id/widget_activity"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:ellipsize="end"
                android:maxLines="1"
                android:text="Nic právě neběží"
                android:textColor="#F4F3F8"
                android:textSize="18sp"
                android:textStyle="bold" />
            <TextView
                android:id="@+id/widget_category"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="TIMIQ"
                android:textColor="#9A8CFF"
                android:textSize="10sp"
                android:textStyle="bold" />
        </LinearLayout>
        <Chronometer
            android:id="@+id/widget_chronometer"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#F4F3F8"
            android:textSize="22sp"
            android:textStyle="bold"
            android:visibility="gone" />
    </LinearLayout>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:layout_marginBottom="6dp"
        android:text="OBLÍBENÉ · DNES"
        android:textColor="#8E92A3"
        android:textSize="10sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/favorite_1"
        style="@style/TimIQWidgetRow" />
    <TextView
        android:id="@+id/favorite_2"
        style="@style/TimIQWidgetRow" />
    <TextView
        android:id="@+id/favorite_3"
        style="@style/TimIQWidgetRow" />
    <TextView
        android:id="@+id/favorite_4"
        style="@style/TimIQWidgetRow" />
    <TextView
        android:id="@+id/favorite_5"
        style="@style/TimIQWidgetRow" />
    <TextView
        android:id="@+id/favorite_6"
        style="@style/TimIQWidgetRow" />
</LinearLayout>
